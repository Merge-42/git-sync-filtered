# Python gitignore - suitable for most projects

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so
*.pyd

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
wheelhouse/
*.egg
*.whl

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
ENV/
env/
.env/
.venv/
venv.bak/

# pyenv
.python-version

# pipenv / poetry
Pipfile.lock
.poetry/

# IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*~ 

# macOS / Windows
.DS_Store
Thumbs.db

# Tests / coverage
.pytest_cache/
.coverage
.coverage.*
.cache
htmlcov/
nosetests.xml
coverage.xml

# Sphinx
_build/

# PyInstaller
*.manifest
*.spec

# Jupyter / IPython
.ipynb_checkpoints
profile_default/
ipython_config.py

# Django / Flask
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
instance/
.webassets-cache

# Mypy
.mypy_cache/
.dmypy.json

# Celery
celerybeat-schedule

# dotenv / env files
.env
.env.*

# Misc
*.mo
*.log
*.tmp
*.bak
*.db

# platform files
.envrc
devbox.*
.devbox/